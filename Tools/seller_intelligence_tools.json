{
  "version": "1.0.0",
  "service": "seller_intelligence_tools",
  "base_url": "http://localhost:8000",
  "auth": {
    "type": "bearer_jwt",
    "login_endpoint": "/auth/login",
    "header": "Authorization: Bearer <token>"
  },
  "tools": [
    {
      "name": "get_dashboard_overview",
      "description": "Get full seller dashboard analytics.",
      "method": "POST",
      "path": "/tools/get_dashboard_overview",
      "arguments": {
        "type": "object",
        "properties": {},
        "additionalProperties": false
      }
    },
    {
      "name": "get_dashboard_summary",
      "description": "Get top-level dashboard KPIs.",
      "method": "POST",
      "path": "/tools/get_dashboard_summary",
      "arguments": {
        "type": "object",
        "properties": {},
        "additionalProperties": false
      }
    },
    {
      "name": "list_products",
      "description": "List seller products with optional filters.",
      "method": "POST",
      "path": "/tools/list_products",
      "arguments": {
        "type": "object",
        "properties": {
          "search": {
            "type": "string"
          },
          "include_archived": {
            "type": "boolean",
            "default": false
          }
        },
        "additionalProperties": false
      }
    },
    {
      "name": "create_product",
      "description": "Create a new product listing.",
      "method": "POST",
      "path": "/tools/create_product",
      "arguments": {
        "type": "object",
        "required": [
          "title",
          "sku",
          "sell_price",
          "stock",
          "marketplace"
        ],
        "properties": {
          "title": { "type": "string" },
          "sku": { "type": "string" },
          "sell_price": { "type": "number", "minimum": 0 },
          "stock": { "type": "integer", "minimum": 0 },
          "marketplace": { "type": "string" }
        },
        "additionalProperties": false
      }
    },
    {
      "name": "update_product",
      "description": "Update an existing product by product_id.",
      "method": "POST",
      "path": "/tools/update_product",
      "arguments": {
        "type": "object",
        "required": ["product_id"],
        "properties": {
          "product_id": { "type": "integer", "minimum": 1 },
          "title": { "type": "string" },
          "sku": { "type": "string" },
          "sell_price": { "type": "number", "minimum": 0 },
          "stock": { "type": "integer", "minimum": 0 },
          "marketplace": { "type": "string" }
        },
        "additionalProperties": false
      }
    },
    {
      "name": "archive_product",
      "description": "Archive (soft-delete) a product by product_id.",
      "method": "POST",
      "path": "/tools/archive_product",
      "arguments": {
        "type": "object",
        "required": ["product_id"],
        "properties": {
          "product_id": { "type": "integer", "minimum": 1 }
        },
        "additionalProperties": false
      }
    },
    {
      "name": "list_orders",
      "description": "List seller orders with optional search.",
      "method": "POST",
      "path": "/tools/list_orders",
      "arguments": {
        "type": "object",
        "properties": {
          "search": { "type": "string" }
        },
        "additionalProperties": false
      }
    },
    {
      "name": "create_order",
      "description": "Create an order with one or more order items.",
      "method": "POST",
      "path": "/tools/create_order",
      "arguments": {
        "type": "object",
        "required": ["order_number", "marketplace", "items"],
        "properties": {
          "order_number": { "type": "string" },
          "marketplace": { "type": "string" },
          "items": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "object",
              "required": ["product_id", "quantity", "unit_price"],
              "properties": {
                "product_id": { "type": "integer" },
                "quantity": { "type": "integer", "minimum": 1 },
                "unit_price": { "type": "number", "minimum": 0 }
              },
              "additionalProperties": false
            }
          }
        },
        "additionalProperties": false
      }
    },
    {
      "name": "predict_buybox",
      "description": "Predict buybox recommendation using external model API/local fallback.",
      "method": "POST",
      "path": "/tools/predict_buybox",
      "arguments": {
        "type": "object",
        "required": [
          "sku",
          "SellPrice",
          "MinCompetitorPrice"
        ],
        "properties": {
          "sku": { "type": "string" },
          "SellPrice": { "type": "number" },
          "ShippingPrice": { "type": "number" },
          "MinCompetitorPrice": { "type": "number" },
          "PositiveFeedbackPercent": { "type": "number" },
          "IsFBA": { "type": "number" }
        },
        "additionalProperties": false
      }
    }
  ]
}

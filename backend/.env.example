DATABASE_URL=postgresql+psycopg://USER:PASSWORD@HOST/DBNAME?sslmode=require
JWT_SECRET_KEY=replace-with-a-long-random-secret
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=120
DATABASE_SCHEMA=seller_intelligence
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
# Path to your trained model (joblib or pickle). Relative to project root when running uvicorn from repo root.
BUYBOX_MODEL_PATH=backend/model/best_model.pkl
# Optional external buybox prediction API (used before local model fallback).
BUYBOX_API_URL=http://willowcore-stage-dashboardapi-lb-582389980.us-east-1.elb.amazonaws.com/predict
BUYBOX_API_TIMEOUT_SECONDS=8

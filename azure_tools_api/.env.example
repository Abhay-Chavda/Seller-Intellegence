DATABASE_URL=postgresql+psycopg://user:password@host/dbname?sslmode=require
DATABASE_SCHEMA=seller_intelligence

JWT_SECRET_KEY=replace-with-a-long-random-secret
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=120

CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,https://your-frontend.onrender.com
AGENT_NAME_PREFIX=seller-agent
PUBLIC_BASE_URL=http://127.0.0.1:8000

# Project / model aliases supported by the API
PROJECT_ENDPOINT=https://your-resource.services.ai.azure.com/api/projects/your-project
AZURE_AI_PROJECT_ENDPOINT=https://your-resource.services.ai.azure.com/api/projects/your-project
MODEL_DEPLOYMENT_NAME=gpt-5.2-chat
AZURE_AI_MODEL_DEPLOYMENT_NAME=gpt-5.2-chat

# If you already created an agent in Foundry, store its reference here.
# Format: "<agent-name>" or "<agent-name>:<version>"
AZURE_EXISTING_AGENT_ID="AgentCreation:2"
AZURE_ENV_NAME="agents-playground-1871"
AZURE_LOCATION="eastus2"
AZURE_SUBSCRIPTION_ID="668a92a1-1277-403c-bd02-6ef2a72f1caa"
AZURE_EXISTING_AIPROJECT_ENDPOINT="https://amar-0558-resource.services.ai.azure.com/api/projects/amar-0558"
AZURE_EXISTING_AIPROJECT_RESOURCE_ID="/subscriptions/668a92a1-1277-403c-bd02-6ef2a72f1caa/resourceGroups/rg-amar-0558/providers/Microsoft.CognitiveServices/accounts/amar-0558-resource/projects/amar-0558"
AZURE_EXISTING_RESOURCE_ID="/subscriptions/668a92a1-1277-403c-bd02-6ef2a72f1caa/resourceGroups/rg-amar-0558/providers/Microsoft.CognitiveServices/accounts/amar-0558-resource"
AZD_ALLOW_NON_EMPTY_FOLDER=true

# Demo / local development:
# run `az login` or `azd auth login` and you do not need the three vars below.
# They are only needed for non-Azure hosted deployments such as Render.
AZURE_CLIENT_ID=
AZURE_TENANT_ID=
AZURE_CLIENT_SECRET=
